<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MathStar — Guía de Diseño v1.0</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
/* =============================================
   DESIGN TOKENS
   ============================================= */
:root {
  /* === PALETA PRINCIPAL === */
  --cosmos-950:  #05080F;
  --cosmos-900:  #0D1422;
  --cosmos-800:  #131D35;
  --cosmos-700:  #1B2848;
  --cosmos-600:  #243460;

/* === ACENTOS VIBRANTES === */
–nova-yellow:   #FFD95A;   /* Estrella principal / CTA primario       */
–nova-yellow-d: #F0BE2A;   /* Hover del amarillo                       */
–nova-green:    #4DEBA8;   /* Correcto / Éxito / Ciencias              */
–nova-green-d:  #2BC98A;   /* Hover del verde                          */
–nova-coral:    #FF6B7A;   /* Error / Vidas / Alerta                   */
–nova-coral-d:  #E04555;   /* Hover del coral                          */
–nova-sky:      #5BC4FF;   /* Matemáticas / Links / Info               */
–nova-sky-d:    #2AAAE0;   /* Hover del cielo                          */
–nova-purple:   #C084FC;   /* Decorativo / Nivel 2 / Bonus             */
–nova-orange:   #FF9F5A;   /* Hints / Racha / Energía                  */

/* === NEUTROS / UI === */
–ui-white:      #FFFFFF;
–ui-100:        rgba(255,255,255,0.90);
–ui-60:         rgba(255,255,255,0.60);
–ui-30:         rgba(255,255,255,0.30);
–ui-10:         rgba(255,255,255,0.08);
–ui-05:         rgba(255,255,255,0.04);

/* === TIPOGRAFÍA === */
–font-display: ‘Fredoka One’, cursive;
–font-body:    ‘Nunito’, sans-serif;
–font-mono:    ‘JetBrains Mono’, monospace;

/* === ESCALAS TIPOGRÁFICAS === */
–text-xs:   0.75rem;    /* 12px */
–text-sm:   0.875rem;   /* 14px */
–text-base: 1rem;       /* 16px */
–text-lg:   1.125rem;   /* 18px */
–text-xl:   1.25rem;    /* 20px */
–text-2xl:  1.5rem;     /* 24px */
–text-3xl:  1.875rem;   /* 30px */
–text-4xl:  2.25rem;    /* 36px */
–text-5xl:  3rem;       /* 48px */

/* === ESPACIADO (4px grid) === */
–space-1:  0.25rem;   /* 4px  */
–space-2:  0.5rem;    /* 8px  */
–space-3:  0.75rem;   /* 12px */
–space-4:  1rem;      /* 16px */
–space-6:  1.5rem;    /* 24px */
–space-8:  2rem;      /* 32px */
–space-12: 3rem;      /* 48px */
–space-16: 4rem;      /* 64px */

/* === BORDES === */
–radius-sm:  8px;
–radius-md:  16px;
–radius-lg:  24px;
–radius-xl:  32px;
–radius-full: 9999px;

/* === SOMBRAS === */
–shadow-yellow: 0 8px 32px rgba(255,217,90,0.35);
–shadow-green:  0 8px 32px rgba(77,235,168,0.30);
–shadow-coral:  0 8px 32px rgba(255,107,122,0.30);
–shadow-sky:    0 8px 32px rgba(91,196,255,0.30);
–shadow-card:   0 4px 24px rgba(0,0,0,0.40);

/* === TRANSICIONES === */
–ease-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
–ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
–dur-fast:    150ms;
–dur-normal:  300ms;
–dur-slow:    600ms;
}

/* =============================================
BASE
============================================= */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
font-family: var(–font-body);
background: var(–cosmos-950);
color: var(–ui-100);
line-height: 1.6;
overflow-x: hidden;
}

/* Grain overlay */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background-image: url(“data:image/svg+xml,%3Csvg viewBox=‘0 0 512 512’ xmlns=‘http://www.w3.org/2000/svg’%3E%3Cfilter id=‘n’%3E%3CfeTurbulence type=‘fractalNoise’ baseFrequency=‘0.75’ numOctaves=‘4’ stitchTiles=‘stitch’/%3E%3C/filter%3E%3Crect width=‘100%25’ height=‘100%25’ filter=‘url(%23n)’ opacity=‘1’/%3E%3C/svg%3E”);
opacity: 0.03;
pointer-events: none;
z-index: 1000;
}

/* =============================================
NAV / SIDEBAR
============================================= */
.layout {
display: grid;
grid-template-columns: 260px 1fr;
min-height: 100vh;
}

.sidebar {
position: sticky;
top: 0;
height: 100vh;
background: var(–cosmos-900);
border-right: 1px solid var(–ui-10);
padding: var(–space-8) var(–space-6);
overflow-y: auto;
display: flex;
flex-direction: column;
gap: var(–space-2);
}

.sidebar-logo {
display: flex;
align-items: center;
gap: var(–space-3);
margin-bottom: var(–space-8);
padding-bottom: var(–space-6);
border-bottom: 1px solid var(–ui-10);
}
.sidebar-logo-icon { font-size: 2rem; }
.sidebar-logo-text { font-family: var(–font-display); font-size: 1.3rem; color: var(–nova-yellow); }
.sidebar-logo-version { font-size: var(–text-xs); color: var(–ui-30); font-weight: 700; letter-spacing: 1px; }

.nav-section-label {
font-size: var(–text-xs);
font-weight: 800;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–ui-30);
margin-top: var(–space-6);
margin-bottom: var(–space-2);
padding-left: var(–space-3);
}

.nav-link {
display: flex;
align-items: center;
gap: var(–space-3);
padding: var(–space-2) var(–space-3);
border-radius: var(–radius-sm);
color: var(–ui-60);
font-weight: 700;
font-size: var(–text-sm);
text-decoration: none;
transition: all var(–dur-fast) var(–ease-smooth);
cursor: pointer;
}
.nav-link:hover, .nav-link.active {
background: var(–ui-10);
color: var(–ui-white);
}
.nav-link.active { color: var(–nova-yellow); }
.nav-link span { font-size: 1rem; }

/* =============================================
MAIN CONTENT
============================================= */
.main {
padding: var(–space-16) var(–space-12);
max-width: 1000px;
}

/* =============================================
SECTION HEADERS
============================================= */
.section { margin-bottom: var(–space-16); }

.section-badge {
display: inline-flex;
align-items: center;
gap: var(–space-2);
background: var(–ui-10);
border: 1px solid var(–ui-10);
border-radius: var(–radius-full);
padding: var(–space-1) var(–space-4);
font-size: var(–text-xs);
font-weight: 800;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–ui-60);
margin-bottom: var(–space-4);
}

.section-title {
font-family: var(–font-display);
font-size: var(–text-4xl);
line-height: 1.1;
margin-bottom: var(–space-3);
}

.section-desc {
font-size: var(–text-lg);
color: var(–ui-60);
max-width: 640px;
margin-bottom: var(–space-8);
font-weight: 600;
}

.divider {
height: 1px;
background: linear-gradient(90deg, var(–ui-10), transparent);
margin: var(–space-16) 0;
}

/* =============================================
HERO
============================================= */
.hero {
margin-bottom: var(–space-16);
padding: var(–space-12);
background: linear-gradient(135deg, var(–cosmos-800) 0%, var(–cosmos-700) 100%);
border: 1px solid var(–ui-10);
border-radius: var(–radius-xl);
position: relative;
overflow: hidden;
}
.hero::before {
content: ‘’;
position: absolute;
top: -60%; right: -20%;
width: 500px; height: 500px;
background: radial-gradient(circle, rgba(255,217,90,0.08) 0%, transparent 60%);
pointer-events: none;
}
.hero::after {
content: ‘🚀’;
position: absolute;
bottom: -20px; right: 40px;
font-size: 8rem;
opacity: 0.08;
}

.hero-tag {
display: inline-block;
background: rgba(255,217,90,0.15);
border: 1px solid rgba(255,217,90,0.3);
border-radius: var(–radius-full);
padding: var(–space-1) var(–space-4);
font-size: var(–text-xs);
font-weight: 800;
letter-spacing: 2px;
color: var(–nova-yellow);
margin-bottom: var(–space-4);
}

.hero-title {
font-family: var(–font-display);
font-size: clamp(2.5rem, 5vw, 4rem);
line-height: 1;
margin-bottom: var(–space-4);
}
.hero-title span {
background: linear-gradient(135deg, var(–nova-yellow), var(–nova-orange), var(–nova-coral));
-webkit-background-clip: text;
-webkit-text-fill-color: transparent;
background-clip: text;
}

.hero-sub {
font-size: var(–text-lg);
color: var(–ui-60);
font-weight: 600;
max-width: 500px;
margin-bottom: var(–space-8);
}

.hero-meta {
display: flex;
gap: var(–space-6);
flex-wrap: wrap;
}
.hero-meta-item {
display: flex;
flex-direction: column;
}
.hero-meta-label { font-size: var(–text-xs); color: var(–ui-30); font-weight: 800; letter-spacing: 1px; text-transform: uppercase; }
.hero-meta-value { font-size: var(–text-base); font-weight: 800; color: var(–ui-100); }

/* =============================================
COLOR SWATCHES
============================================= */
.color-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
gap: var(–space-4);
}

.color-group { margin-bottom: var(–space-8); }
.color-group-title {
font-size: var(–text-sm);
font-weight: 800;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–ui-30);
margin-bottom: var(–space-4);
}

.swatch {
border-radius: var(–radius-md);
overflow: hidden;
border: 1px solid var(–ui-10);
cursor: pointer;
transition: transform var(–dur-fast) var(–ease-spring);
}
.swatch:hover { transform: translateY(-4px) scale(1.02); }

.swatch-color {
height: 100px;
position: relative;
display: flex;
align-items: flex-end;
padding: var(–space-3);
}
.swatch-copy-hint {
font-size: var(–text-xs);
font-weight: 700;
opacity: 0;
transition: opacity var(–dur-fast);
background: rgba(0,0,0,0.4);
padding: 2px 8px;
border-radius: 4px;
backdrop-filter: blur(4px);
}
.swatch:hover .swatch-copy-hint { opacity: 1; }

.swatch-info {
background: var(–cosmos-800);
padding: var(–space-3) var(–space-4);
}
.swatch-name { font-size: var(–text-sm); font-weight: 800; margin-bottom: 2px; }
.swatch-hex  { font-family: var(–font-mono); font-size: var(–text-xs); color: var(–ui-60); }
.swatch-use  { font-size: var(–text-xs); color: var(–ui-30); font-weight: 700; margin-top: var(–space-1); }

/* Dark swatches row */
.dark-swatches {
display: grid;
grid-template-columns: repeat(5, 1fr);
gap: var(–space-2);
margin-bottom: var(–space-8);
}
.dark-swatch {
border-radius: var(–radius-sm);
height: 60px;
border: 1px solid var(–ui-10);
cursor: pointer;
transition: all var(–dur-fast) var(–ease-spring);
position: relative;
overflow: hidden;
}
.dark-swatch:hover { transform: scaleY(1.15); }
.dark-swatch-label {
position: absolute;
bottom: 0; left: 0; right: 0;
text-align: center;
font-family: var(–font-mono);
font-size: 9px;
font-weight: 700;
color: var(–ui-60);
padding: 2px 0;
background: rgba(0,0,0,0.3);
}

/* =============================================
TYPOGRAPHY
============================================= */
.type-scale { display: flex; flex-direction: column; gap: var(–space-6); }

.type-row {
display: grid;
grid-template-columns: 120px 1fr auto;
align-items: baseline;
gap: var(–space-6);
padding: var(–space-4) 0;
border-bottom: 1px solid var(–ui-05);
}
.type-meta { display: flex; flex-direction: column; }
.type-size-label { font-family: var(–font-mono); font-size: var(–text-xs); color: var(–ui-30); }
.type-name-label { font-size: var(–text-xs); font-weight: 800; color: var(–ui-60); }
.type-px { font-family: var(–font-mono); font-size: var(–text-xs); color: var(–ui-30); text-align: right; }

.font-showcase {
display: grid;
grid-template-columns: 1fr 1fr;
gap: var(–space-6);
margin-bottom: var(–space-8);
}
.font-card {
background: var(–cosmos-800);
border: 1px solid var(–ui-10);
border-radius: var(–radius-lg);
padding: var(–space-8);
}
.font-card-name {
font-size: var(–text-xs);
font-weight: 800;
letter-spacing: 2px;
text-transform: uppercase;
color: var(–ui-30);
margin-bottom: var(–space-4);
}
.font-display-sample { font-family: var(–font-display); font-size: 3rem; line-height: 1; color: var(–nova-yellow); margin-bottom: var(–space-3); }
.font-body-sample { font-family: var(–font-body); font-size: 1.1rem; font-weight: 700; color: var(–ui-100); margin-bottom: var(–space-3); }
.font-mono-sample { font-family: var(–font-mono); font-size: 0.9rem; color: var(–nova-green); }
.font-usage { font-size: var(–text-xs); color: var(–ui-30); font-weight: 700; margin-top: var(–space-3); border-top: 1px solid var(–ui-10); padding-top: var(–space-3); }

/* =============================================
COMPONENTS
============================================= */
.component-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
gap: var(–space-6);
}

.component-card {
background: var(–cosmos-800);
border: 1px solid var(–ui-10);
border-radius: var(–radius-lg);
overflow: hidden;
}
.component-preview {
padding: var(–space-8);
display: flex;
align-items: center;
justify-content: center;
min-height: 140px;
background: var(–cosmos-900);
gap: var(–space-4);
flex-wrap: wrap;
}
.component-info {
padding: var(–space-4) var(–space-6);
border-top: 1px solid var(–ui-10);
}
.component-name { font-size: var(–text-sm); font-weight: 800; margin-bottom: 2px; }
.component-desc { font-size: var(–text-xs); color: var(–ui-60); }

/* === BUTTON STYLES (los propios del juego) === */
.btn {
font-family: var(–font-display);
border: none;
border-radius: var(–radius-full);
cursor: pointer;
transition: all var(–dur-normal) var(–ease-spring);
display: inline-flex;
align-items: center;
gap: var(–space-2);
font-size: var(–text-lg);
padding: var(–space-3) var(–space-8);
position: relative;
overflow: hidden;
}
.btn-primary {
background: linear-gradient(135deg, var(–nova-yellow), var(–nova-orange));
color: var(–cosmos-900);
box-shadow: var(–shadow-yellow);
}
.btn-primary:hover { transform: translateY(-3px) scale(1.04); box-shadow: 0 12px 40px rgba(255,217,90,0.5); }

.btn-success {
background: linear-gradient(135deg, var(–nova-green), #2BC98A);
color: var(–cosmos-900);
box-shadow: var(–shadow-green);
}
.btn-success:hover { transform: translateY(-3px) scale(1.04); }

.btn-ghost {
background: var(–ui-10);
border: 1.5px solid var(–ui-30);
color: var(–ui-100);
padding: calc(var(–space-3) - 1.5px) var(–space-8);
}
.btn-ghost:hover { background: var(–ui-10); border-color: var(–ui-60); transform: translateY(-2px); }

/* === ANSWER BUTTON === */
.answer-btn-demo {
background: var(–ui-10);
border: 2px solid var(–ui-10);
border-radius: var(–radius-lg);
padding: var(–space-4) var(–space-6);
color: var(–ui-100);
font-family: var(–font-display);
font-size: var(–text-2xl);
cursor: pointer;
transition: all var(–dur-normal) var(–ease-spring);
min-width: 80px;
text-align: center;
}
.answer-btn-demo:hover { border-color: var(–nova-yellow); box-shadow: var(–shadow-yellow); transform: translateY(-4px); }
.answer-btn-demo.correct { border-color: var(–nova-green); background: rgba(77,235,168,0.15); box-shadow: var(–shadow-green); }
.answer-btn-demo.wrong   { border-color: var(–nova-coral); background: rgba(255,107,122,0.15); box-shadow: var(–shadow-coral); }

/* === CARD === */
.game-card-demo {
background: var(–ui-10);
border: 1.5px solid var(–ui-10);
border-radius: var(–radius-xl);
padding: var(–space-6);
backdrop-filter: blur(10px);
transition: all var(–dur-normal) var(–ease-spring);
}
.game-card-demo:hover { border-color: var(–ui-30); transform: translateY(-4px); box-shadow: var(–shadow-card); }

/* === BADGE / TAG === */
.tag {
display: inline-flex;
align-items: center;
gap: var(–space-1);
border-radius: var(–radius-full);
padding: var(–space-1) var(–space-3);
font-size: var(–text-xs);
font-weight: 800;
letter-spacing: 1px;
}
.tag-math    { background: rgba(91,196,255,0.15); border: 1px solid rgba(91,196,255,0.4); color: var(–nova-sky); }
.tag-science { background: rgba(77,235,168,0.15); border: 1px solid rgba(77,235,168,0.4); color: var(–nova-green); }
.tag-bonus   { background: rgba(192,132,252,0.15); border: 1px solid rgba(192,132,252,0.4); color: var(–nova-purple); }
.tag-warning { background: rgba(255,159,90,0.15); border: 1px solid rgba(255,159,90,0.4); color: var(–nova-orange); }

/* === HUD STAT === */
.hud-stat {
background: var(–ui-10);
border: 1.5px solid var(–ui-10);
border-radius: var(–radius-md);
padding: var(–space-3) var(–space-4);
display: flex;
align-items: center;
gap: var(–space-3);
backdrop-filter: blur(10px);
}
.hud-stat-icon { font-size: 1.5rem; }
.hud-stat-val  { font-family: var(–font-display); font-size: var(–text-2xl); color: var(–nova-yellow); line-height: 1; }
.hud-stat-lbl  { font-size: var(–text-xs); color: var(–ui-30); font-weight: 800; text-transform: uppercase; letter-spacing: 1px; }

/* === PROGRESS BAR === */
.progress-demo { width: 100%; }
.progress-track {
height: 12px;
background: var(–ui-10);
border-radius: var(–radius-full);
overflow: hidden;
}
.progress-fill {
height: 100%;
border-radius: var(–radius-full);
background: linear-gradient(90deg, var(–nova-green), var(–nova-sky));
transition: width 0.5s var(–ease-smooth);
position: relative;
}
.progress-fill::after {
content: ‘’;
position: absolute;
top: 0; right: 0; bottom: 0;
width: 30%;
background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3));
}

/* === TOAST === */
.toast-demo {
background: var(–cosmos-800);
border-radius: var(–radius-full);
padding: var(–space-3) var(–space-6);
font-family: var(–font-display);
font-size: var(–text-lg);
display: inline-flex;
align-items: center;
gap: var(–space-3);
box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}
.toast-success { border: 2px solid var(–nova-green); color: var(–nova-green); }
.toast-error   { border: 2px solid var(–nova-coral); color: var(–nova-coral); }

/* =============================================
SPACING GRID
============================================= */
.space-grid { display: flex; flex-direction: column; gap: var(–space-3); }
.space-row { display: flex; align-items: center; gap: var(–space-6); }
.space-bar { background: linear-gradient(90deg, var(–nova-yellow), transparent); border-radius: 2px; height: 20px; }
.space-meta { display: flex; gap: var(–space-4); }
.space-label { font-family: var(–font-mono); font-size: var(–text-xs); color: var(–ui-60); min-width: 80px; }
.space-px    { font-family: var(–font-mono); font-size: var(–text-xs); color: var(–ui-30); }

/* =============================================
ICON GRID
============================================= */
.icon-grid {
display: grid;
grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
gap: var(–space-3);
}
.icon-item {
background: var(–cosmos-800);
border: 1px solid var(–ui-10);
border-radius: var(–radius-md);
padding: var(–space-4);
text-align: center;
cursor: pointer;
transition: all var(–dur-fast) var(–ease-spring);
}
.icon-item:hover { border-color: var(–ui-30); transform: scale(1.08); }
.icon-emoji { font-size: 2rem; display: block; margin-bottom: var(–space-2); }
.icon-name  { font-size: 9px; color: var(–ui-30); font-weight: 800; letter-spacing: 1px; text-transform: uppercase; }

/* =============================================
MOTION GUIDE
============================================= */
.motion-demo {
display: flex;
gap: var(–space-6);
align-items: center;
flex-wrap: wrap;
}
.motion-ball {
width: 50px; height: 50px;
border-radius: 50%;
background: linear-gradient(135deg, var(–nova-yellow), var(–nova-orange));
cursor: pointer;
}
.motion-ball.bounce { animation: demoBounce 2s var(–ease-spring) infinite; }
.motion-ball.float  { animation: demoFloat 3s ease-in-out infinite; }
.motion-ball.pulse  { animation: demoPulse 1.5s ease-in-out infinite; }
.motion-ball.spin   { animation: demoSpin 2s linear infinite; border-radius: var(–radius-sm); }

@keyframes demoBounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-20px)} }
@keyframes demoFloat  { 0%,100%{transform:translateY(0) rotate(-3deg)} 50%{transform:translateY(-12px) rotate(3deg)} }
@keyframes demoPulse  { 0%,100%{transform:scale(1);opacity:1} 50%{transform:scale(1.2);opacity:0.7} }
@keyframes demoSpin   { from{transform:rotate(0)} to{transform:rotate(360deg)} }

.motion-item { display: flex; flex-direction: column; align-items: center; gap: var(–space-3); }
.motion-label { font-size: var(–text-xs); color: var(–ui-60); font-weight: 800; text-align: center; }

/* =============================================
CODE TOKEN
============================================= */
.code-block {
background: var(–cosmos-900);
border: 1px solid var(–ui-10);
border-radius: var(–radius-md);
padding: var(–space-4) var(–space-6);
font-family: var(–font-mono);
font-size: var(–text-sm);
color: var(–nova-green);
overflow-x: auto;
line-height: 1.8;
}
.code-comment { color: var(–ui-30); }
.code-key     { color: var(–nova-sky); }
.code-val     { color: var(–nova-yellow); }
.code-str     { color: var(–nova-coral); }

/* =============================================
DO/DON’T
============================================= */
.dos-donts {
display: grid;
grid-template-columns: 1fr 1fr;
gap: var(–space-6);
}
.do-card, .dont-card {
border-radius: var(–radius-lg);
overflow: hidden;
}
.do-card   { border: 1.5px solid rgba(77,235,168,0.3); }
.dont-card { border: 1.5px solid rgba(255,107,122,0.3); }
.dd-header {
padding: var(–space-3) var(–space-6);
font-size: var(–text-xs);
font-weight: 800;
letter-spacing: 2px;
text-transform: uppercase;
display: flex;
align-items: center;
gap: var(–space-2);
}
.do-card .dd-header   { background: rgba(77,235,168,0.1); color: var(–nova-green); }
.dont-card .dd-header { background: rgba(255,107,122,0.1); color: var(–nova-coral); }
.dd-body { padding: var(–space-6); background: var(–cosmos-800); }
.dd-item { font-size: var(–text-sm); font-weight: 700; color: var(–ui-60); padding: var(–space-2) 0; border-bottom: 1px solid var(–ui-05); }
.dd-item:last-child { border-bottom: none; }
.dd-item::before { margin-right: var(–space-2); }
.do-card .dd-item::before   { content: ‘✓’; color: var(–nova-green); }
.dont-card .dd-item::before { content: ‘✗’; color: var(–nova-coral); }

/* =============================================
COPY TOOLTIP
============================================= */
.copied-toast {
position: fixed;
bottom: 2rem;
right: 2rem;
background: var(–cosmos-800);
border: 1.5px solid var(–nova-green);
border-radius: var(–radius-full);
padding: var(–space-3) var(–space-6);
font-family: var(–font-display);
color: var(–nova-green);
font-size: var(–text-base);
box-shadow: var(–shadow-green);
transform: translateY(100px);
transition: transform 0.4s var(–ease-spring);
z-index: 999;
}
.copied-toast.show { transform: translateY(0); }

/* Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(–cosmos-900); }
::-webkit-scrollbar-thumb { background: var(–ui-30); border-radius: 3px; }
</style>

